VITE_GEMINI_API_KEY=

# Supabase project URL + publishable/anon key (safe for client-side use)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe publishable key (safe for client-side use). The secret key and
# webhook signing secret are server-side only — set them as Supabase Edge
# Function secrets, never in this file.
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe recurring Price IDs, one per pricing tier
VITE_STRIPE_PRICE_BASIC=
VITE_STRIPE_PRICE_PRO=
VITE_STRIPE_PRICE_PREMIUM=
